{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/source-registry.schema.json",
  "title": "OpenClaw Source Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["sourceId", "sourceType", "name", "trustTier", "allowedUses", "lastCheckedAt"],
    "properties": {
      "sourceId": { "type": "string", "minLength": 1 },
      "sourceType": { "enum": ["filing", "transcript", "ir", "press_release", "macro", "market_data", "analyst", "news", "internal", "social"] },
      "name": { "type": "string", "minLength": 1 },
      "baseUrl": { "type": ["string", "null"] },
      "trustTier": { "enum": ["primary", "high", "medium", "low", "sentiment_only"] },
      "allowedUses": { "type": "array", "minItems": 1, "items": { "enum": ["fact", "management_guidance", "estimate", "market_signal", "sentiment", "internal_note", "background"] } },
      "refreshCadence": { "type": "string" },
      "storagePolicy": { "type": "string" },
      "failureMode": { "type": "string" },
      "lastCheckedAt": { "type": "string", "minLength": 1 },
      "notes": { "type": "string" }
    },
    "additionalProperties": false
  }
}
