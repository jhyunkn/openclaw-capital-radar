{
  "name": "openclaw-capital-radar",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Capital Radar - live investing blueprint and market landscape report.",
  "scripts": {
    "generate:live": "node live-data-adapter.cjs",
    "generate:live:partial": "node live-data-adapter.cjs --allow-stale-fred",
    "validate": "node validate-report.cjs data/report-state.live.json",
    "validate:action-specificity": "node scripts/validate-authoritative-action-specificity.cjs",
    "report": "node generate-daily-report.cjs data/report-state.live.json outputs/live-capital-radar.md",
    "build:candles": "node scripts/build-market-candles.cjs",
    "refresh:money-cash": "node scripts/refresh-money-cash-cache.cjs",
    "validate:money-cash-cache": "node scripts/validate-money-cash-cache.cjs",
    "generate:money-cash": "node scripts/generate-money-cash-state.cjs && node scripts/validate-money-cash-cache.cjs && node scripts/generate-money-cash-annotations.cjs",
    "validate:research-backbone": "node scripts/validate-research-engine.cjs && node scripts/validate-thesis-backbone.cjs",
    "status:research-backbone": "node scripts/generate-research-engine-status.cjs && node scripts/generate-thesis-dossier-status.cjs",
    "build:prod": "node scripts/run-build-pipeline.cjs",
    "build": "npm run build:prod",
    "build:fast": "node scripts/run-fast-build.cjs",
    "verify:fast-build": "node scripts/run-fast-build.cjs",
    "lane:list": "node scripts/run-build-lane.cjs --list",
    "refresh:data": "node scripts/run-build-lane.cjs data",
    "research:audit": "node scripts/run-build-lane.cjs audit",
    "validate:lane": "node scripts/run-build-lane.cjs validation",
    "build:ship": "node scripts/run-build-lane.cjs ship",
    "build:full-lane": "node scripts/run-build-lane.cjs full",
    "preview:homepage-registry": "node scripts/render-homepage-from-registry-preview.cjs",
    "preview:homepage-registry:strict": "node scripts/render-homepage-from-registry-preview.cjs --strict && node scripts/assert-homepage-registry-preview-ok.cjs",
    "gate:homepage-registry": "node scripts/assert-homepage-registry-preview-ok.cjs",
    "migrate:homepage-registry:remove-legacy-cleanup": "node scripts/remove-homepage-legacy-cleanup-dependency.cjs",
    "migrate:homepage-registry:strict": "npm run preview:homepage-registry:strict && npm run migrate:homepage-registry:remove-legacy-cleanup",
    "preflight:thesis": "node scripts/preflight-thesis-dossiers.cjs",
    "build:experimental:thesis": "node scripts/generate-thesis-dossiers.cjs && node scripts/inject-thesis-dossiers-workbenches.cjs && node scripts/validate-thesis-dossiers.cjs",
    "build:experimental:evidence": "node scripts/generate-research-evidence-packets.cjs && node scripts/inject-research-evidence-workbenches.cjs && node scripts/validate-research-evidence-packets.cjs",
    "build:experimental:all": "npm run build:prod && npm run build:experimental:thesis && npm run build:experimental:evidence",
    "generate:operating-brain": "node scripts/generate-operating-brain-artifacts.cjs",
    "render:operating-brain": "node scripts/render-operating-brain-home.cjs",
    "validate:operating-brain": "node scripts/validate-operating-brain.cjs",
    "gate:deploy": "node scripts/deploy-gate-meaningful-change.cjs",
    "validate:intelligence": "node scripts/validate-intelligence-artifacts.cjs",
    "generate:delta": "node scripts/generate-delta-brief.cjs",
    "generate:ranking": "node scripts/generate-candidate-ranking.cjs",
    "collect:news": "node scripts/collect-news-catalysts.cjs",
    "collect:xbrl": "node scripts/collect-sec-xbrl-fundamentals.cjs",
    "collect:all": "npm run collect:news && npm run collect:xbrl",
    "review:source-confidence": "node scripts/generate-source-confidence-review.cjs"
  },
  "engines": {
    "node": "20.x"
  }
}
