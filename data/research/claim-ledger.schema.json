{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/claim-ledger.schema.json",
  "title": "OpenClaw Claim Ledger",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["claimId", "ticker", "claim", "claimType", "status", "supportingEvidenceIds", "contradictingEvidenceIds", "firstObservedAt", "lastReviewedAt", "confidence", "ownerAgent", "requiresHumanReview"],
    "properties": {
      "claimId": { "type": "string", "pattern": "^claim-[A-Z0-9.-]+-[a-z0-9-]+$" },
      "ticker": { "type": "string", "pattern": "^[A-Z0-9.-]+$" },
      "claim": { "type": "string", "minLength": 1 },
      "claimType": { "enum": ["fact", "inference", "estimate", "thesis_component", "risk", "catalyst"] },
      "status": { "enum": ["active", "weakened", "contradicted", "invalidated", "retired"] },
      "supportingEvidenceIds": { "type": "array", "items": { "type": "string" } },
      "contradictingEvidenceIds": { "type": "array", "items": { "type": "string" } },
      "firstObservedAt": { "type": "string", "minLength": 1 },
      "lastReviewedAt": { "type": "string", "minLength": 1 },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "ownerAgent": { "type": "string", "minLength": 1 },
      "requiresHumanReview": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
