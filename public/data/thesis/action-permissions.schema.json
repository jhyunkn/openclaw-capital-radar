{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/action-permissions.schema.json",
  "title": "OpenClaw Action Permission Grammar",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["permission", "definition", "allowedWhen", "requiresHumanReview"],
    "properties": {
      "permission": { "enum": ["monitor", "research", "review", "prepare_add", "prepare_trim", "prepare_exit", "human_decision_required"] },
      "definition": { "type": "string", "minLength": 1 },
      "allowedWhen": { "type": "array", "minItems": 1, "items": { "type": "string" } },
      "blockedWhen": { "type": "array", "items": { "type": "string" } },
      "requiresHumanReview": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
