# Vercel
.vercel

# Node
node_modules/

# OS
.DS_Store

# Generated build output
# Vercel rebuilds public/ from source at deploy time
public/

# Generated data
# Price chart data regenerated by build-market-candles.cjs via Yahoo Finance
data/market-candles/

# Generated intelligence state rebuilt by pipeline
data/intelligence/

# Transient local verification reports
outputs/build-lane-last-run.json
outputs/fast-build-report.json

# Kept data (stable inputs for the Vercel build)
# data/cache/        - FRED series cache; keep because FRED 504s at build time
# data/report-state.live.json - authoritative live state (candidates, holdings)
# data/fundamentals.manual.json - manually maintained fundamentals
# data/research/     - schemas and source registry
# data/thesis/       - schemas
# tickers/           - curated opportunity dossiers (source, not generated)
.env*
