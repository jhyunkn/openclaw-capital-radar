{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/evidence-packets.schema.json",
  "title": "OpenClaw Research Evidence Packets",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "ticker",
      "sourceType",
      "sourceName",
      "publishedAt",
      "retrievedAt",
      "claim",
      "claimType",
      "confidence",
      "stalenessRisk",
      "materiality",
      "requiresHumanReview"
    ],
    "properties": {
      "id": { "type": "string", "pattern": "^evidence-[A-Z0-9.-]+-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$" },
      "ticker": { "type": "string", "pattern": "^[A-Z0-9.-]+$" },
      "sourceType": { "enum": ["filing", "transcript", "ir", "press_release", "macro", "analyst", "news", "internal", "social"] },
      "sourceName": { "type": "string", "minLength": 1 },
      "sourceUrl": { "type": ["string", "null"] },
      "publishedAt": { "type": "string", "minLength": 1 },
      "retrievedAt": { "type": "string", "minLength": 1 },
      "authorOrIssuer": { "type": ["string", "null"] },
      "claim": { "type": "string", "minLength": 1 },
      "claimType": { "enum": ["fact", "management_guidance", "estimate", "market_signal", "inference", "interpretation", "speculation"] },
      "affectedThesisIds": { "type": "array", "items": { "type": "string" } },
      "supports": { "type": "array", "items": { "type": "string" } },
      "weakens": { "type": "array", "items": { "type": "string" } },
      "contradicts": { "type": "array", "items": { "type": "string" } },
      "neutralTo": { "type": "array", "items": { "type": "string" } },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "stalenessRisk": { "enum": ["low", "medium", "high"] },
      "materiality": { "enum": ["low", "medium", "high", "critical"] },
      "requiresHumanReview": { "type": "boolean" },
      "notes": { "type": "string" }
    },
    "additionalProperties": false
  }
}
