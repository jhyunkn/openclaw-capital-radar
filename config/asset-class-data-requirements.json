{
  "version": 2,
  "mission": "asset-class-data-foundation",
  "macroGate": {
    "levels": {
      "PARTIAL": {
        "label": "Asset-Class Research Matrix: PARTIAL DATA COVERAGE",
        "allowedUse": "May display partial asset-class reads only with explicit missing-evidence and confidence caveats.",
        "requires": [
          "all_asset_classes_declared",
          "all_core_datasets_declared",
          "all_dataset_sources_declared",
          "freshness_rules_declared",
          "confidence_labels_declared",
          "missing_evidence_visible"
        ]
      },
      "CORE": {
        "label": "Asset-Class Research Matrix: CORE MACRO SPINE COVERAGE",
        "allowedUse": "May generate a serious first Macro landscape read, but cannot claim full cross-asset completeness.",
        "requiresAssetClasses": [
          "money_cash",
          "duration",
          "credit",
          "equity_ownership",
          "fx_dollar",
          "volatility_insurance"
        ],
        "requires": [
          "each_core_spine_asset_class_has_at_least_partial_validated_coverage",
          "no_stale_core_dataset_silently_used",
          "portfolio_implication_includes_missing_evidence_caveat"
        ]
      },
      "FULL": {
        "label": "Asset-Class Research Matrix: FULL DATA COVERAGE",
        "allowedUse": "May claim full asset-class matrix coverage if all required asset classes have at least partial validated data and no stale core data.",
        "requires": [
          "all_asset_classes_have_at_least_partial_validated_coverage",
          "all_core_datasets_are_AUTH_VERIFIED_PROXY_or_explicitly_MISSING",
          "no_stale_core_dataset_silently_used",
          "all_missing_evidence_visible"
        ]
      }
    }
  },
  "phasePolicy": {
    "phase1CoreSpine": [
      "money_cash",
      "duration",
      "credit",
      "equity_ownership",
      "fx_dollar",
      "volatility_insurance"
    ],
    "phase2Expansion": [
