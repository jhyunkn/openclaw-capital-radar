{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/contradiction-flags.schema.json",
  "title": "OpenClaw Contradiction Flags",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["flagId", "ticker", "claimId", "contradictingEvidenceId", "severity", "reason", "recommendedAction", "requiresHumanReview", "surfacedForReview"],
    "properties": {
      "flagId": { "type": "string", "pattern": "^contradiction-[A-Z0-9.-]+-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$" },
      "ticker": { "type": "string", "pattern": "^[A-Z0-9.-]+$" },
      "claimId": { "type": "string" },
      "contradictingEvidenceId": { "type": "string" },
      "severity": { "enum": ["low", "medium", "high", "critical"] },
      "reason": { "type": "string", "minLength": 1 },
      "recommendedAction": { "enum": ["review", "revise_thesis", "reduce_confidence", "action_blocked"] },
      "requiresHumanReview": { "type": "boolean" },
      "surfacedForReview": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
