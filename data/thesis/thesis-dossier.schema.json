{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/thesis-dossier.schema.json",
  "title": "OpenClaw Thesis Dossiers",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["ticker", "companyName", "dossierId", "lastUpdatedAt", "positionStatus", "positionRole", "coreThesis", "variantPerception", "keyDrivers", "evidenceMap", "bearCase", "invalidationTriggers", "addTriggers", "trimTriggers", "exitTriggers", "riskExposures", "portfolioConflicts", "openQuestions", "currentActionPermission", "confidence", "humanReviewRequired"],
    "properties": {
      "ticker": { "type": "string", "pattern": "^[A-Z0-9.-]+$" },
      "companyName": { "type": "string", "minLength": 1 },
      "dossierId": { "type": "string", "pattern": "^thesis-[A-Z0-9.-]+$" },
      "lastUpdatedAt": { "type": "string", "minLength": 1 },
      "lastHumanReviewedAt": { "type": ["string", "null"] },
      "positionStatus": { "enum": ["holding", "watchlist", "candidate", "exited"] },
      "positionRole": { "enum": ["core_compounder", "tactical", "hedge", "optionality", "macro_expression", "speculative"] },
      "coreThesis": { "type": "string", "minLength": 1 },
      "variantPerception": { "type": "string", "minLength": 1 },
      "keyDrivers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
      "evidenceMap": {
        "type": "object",
        "required": ["supporting", "weakening", "contradicting"],
        "properties": {
          "supporting": { "type": "array", "items": { "type": "string" } },
          "weakening": { "type": "array", "items": { "type": "string" } },
          "contradicting": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "bearCase": { "type": "string", "minLength": 1 },
      "invalidationTriggers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
      "addTriggers": { "type": "array", "items": { "type": "string" } },
      "trimTriggers": { "type": "array", "items": { "type": "string" } },
      "exitTriggers": { "type": "array", "items": { "type": "string" } },
      "riskExposures": { "type": "array", "items": { "type": "string" } },
      "portfolioConflicts": { "type": "array", "items": { "type": "string" } },
      "openQuestions": { "type": "array", "items": { "type": "string" } },
      "currentActionPermission": { "enum": ["monitor", "research", "review", "prepare_add", "prepare_trim", "prepare_exit", "human_decision_required"] },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "humanReviewRequired": { "type": "boolean" }
    },
    "additionalProperties": false
  }
}
